# ==============================================================================
# OdooAI — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env — it contains secrets.
# ==============================================================================

# ---- Application ----
ENVIRONMENT=development          # development | staging | production
APP_NAME=odooai

# ---- Database ----
DATABASE_URL=sqlite:///odooai.db  # SQLite for dev, PostgreSQL for prod
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/odooai

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Security ----
# JWT signing key — minimum 32 characters. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change_me_in_production_must_be_at_least_32_chars

# AES-256 key for encrypting Odoo API keys at rest. Generate with:
#   python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
ODOO_CRYPTO_KEY=
# Previous key for rotation (set when rotating, remove after re-encryption)
ODOO_CRYPTO_KEY_PREVIOUS=

# ---- LLM ----
# Anthropic API key for Claude models
ANTHROPIC_API_KEY=

# ---- Stripe (Phase 2) ----
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ---- Email (Phase 2) ----
# EMAIL_FROM=noreply@odooai.com
# RESEND_API_KEY=
